<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="800.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lms_group_01.Controller.Admin.AdminEnrollmentController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" spacing="16.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="Enrollment Management" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f1f2f6; -fx-padding: 10; -fx-background-radius: 10;">
                    <children>
                        <TextField fx:id="txtSearchEnrollment" prefHeight="35.0" prefWidth="260.0" promptText="Search student reg or course code" />
                        <ComboBox fx:id="cmbBatchFilter" prefHeight="35.0" prefWidth="130.0" promptText="Batch" />
                        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button onAction="#btnOnActionAddEnrollment" prefHeight="35.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Add Enrollment" />
                                <Button onAction="#btnOnActionMakeCompleted" prefHeight="35.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;" text="Completed" />
                                <Button onAction="#btnOnActionMakeDropped" prefHeight="35.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Dropped" />
                                <Button onAction="#btnOnActionRefresh" prefHeight="35.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="Refresh" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <TableView fx:id="tblEnrollments" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colStudentReg" prefWidth="115.0" text="Student Reg" />
                        <TableColumn fx:id="colStudentName" prefWidth="165.0" text="Student Name" />
                        <TableColumn fx:id="colBatch" prefWidth="80.0" text="Batch" />
                        <TableColumn fx:id="colCourseCode" prefWidth="110.0" text="Course Code" />
                        <TableColumn fx:id="colCourseName" prefWidth="170.0" text="Course Name" />
                        <TableColumn fx:id="colEnrollmentDate" prefWidth="110.0" text="Date" />
                        <TableColumn fx:id="colStatus" prefWidth="90.0" text="Status" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
